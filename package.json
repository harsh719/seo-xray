{
  "name": "auditpilot",
  "version": "1.0.0",
  "description": "Full-stack SEO audit agent powered by DataForSEO",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npx vite --port 3000",
    "build": "cd client && npx vite build",
    "start": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "uuid": "^10.0.0",
    "docx": "^8.5.0",
    "p-queue": "^8.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
